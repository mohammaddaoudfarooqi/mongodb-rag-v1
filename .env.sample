# MongoDB Atlas connection — same value MCP server uses (single source of truth)
MDB_MCP_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MDB_DATABASE=knowledge_base

# Embeddings — asymmetric, pluggable, both pinned to 1024 dims
EMBEDDING_PROVIDER=atlas
EMBEDDING_DIMENSIONS=1024
EMBEDDING_DOC_MODEL=voyage-4
EMBEDDING_QUERY_MODEL=voyage-4-lite

# Required when EMBEDDING_PROVIDER=atlas
MDB_ATLAS_API_KEY=
# Override only if your project is in a non-default region
MDB_ATLAS_EMBEDDING_URL=

# Required when EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=

# Hybrid retrieval weights — vector-leaning by default
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_LEXICAL_WEIGHT=0.3

# Top-k chunks pulled per query
RETRIEVAL_K=5

# Bedrock LLM
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# AWS credentials use the standard chain (env vars, profile, SSO, role)
